# Database (Railway provides this automatically when you add a Postgres service)
DATABASE_URL="postgresql://user:password@host:5432/pokemon_shows"

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-secret-here"

# App URL — set to your Railway domain after first deploy
NEXT_PUBLIC_APP_URL="https://your-app.railway.app"

# Cloudinary — create a free account at cloudinary.com
# In your Cloudinary dashboard: Settings > Upload > Add upload preset (set to "Unsigned")
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="pokeshow-uploads"
